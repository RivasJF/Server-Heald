// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
 binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  CLIENT
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  phoneNumber  String?
  birthDate    DateTime?
  role         Role
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  doctor       Doctor?
  appointments Appointment[]
}

model Doctor {
  id                  String               @id @default(cuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id])
  speciality          String?
  biography           String?
  schedule            DoctorSchedule?
  clinicLocation      ClinicLocation?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  appointments        Appointment[]
  dayOffs             DoctorDayOff[]
  dayCloses           DoctorDayClose[]
  serviceStatus       DoctorServiceStatus?
}

enum Day {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model DoctorSchedule {
  id               String              @id @default(cuid())
  doctorId         String              @unique
  doctor           Doctor              @relation(fields: [doctorId], references: [id])
  consultationTime Int                 @default(20)
  days             DoctorScheduleDay[]
  breaks           DoctorBreak[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model DoctorBreak {
  id         String         @id @default(cuid())
  scheduleId String
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id])
  day        Day // "MON", "TUE"...
  startTime  String // "13:00"
  endTime    String // "14:00"
}

model DoctorScheduleDay {
  id         String         @id @default(cuid())
  scheduleId String
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id])
  day        Day // "MON", "TUE"...
  startTime  String // "09:00"
  endTime    String // "17:00"
}

model ClinicLocation {
  id           String        @id @default(cuid())
  latitude     Float
  longitude    Float
  address      String
  doctorId     String        @unique
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Appointment {
  id               String            @id @default(cuid())
  doctorId         String
  patientId        String
  clinicLocationId String
  startTime        DateTime
  endTime          DateTime
  doctor           Doctor            @relation(fields: [doctorId], references: [id])
  patient          User              @relation(fields: [patientId], references: [id])
  clinicLocation   ClinicLocation    @relation(fields: [clinicLocationId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model DoctorDayOff {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime 
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  createdAt DateTime @default(now())
}

model DoctorDayClose {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime 
  closedAt  String // hora en que dejó de trabajar
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  createdAt DateTime @default(now())
}

model DoctorServiceStatus {
  id        String   @id @default(cuid())
  doctorId  String   @unique
  active    Boolean  @default(true) // true = recibe citas, false = cerrado indefinidamente
  updatedAt DateTime @updatedAt
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}