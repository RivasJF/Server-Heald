{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "decoratorMetadata": true,
      "legacyDecorator": true
    },
    "target": "es2023"
  },
  "module": {
    "type": "commonjs"
  },
  "sourceMaps": false,
  "minify": false,
  "exclude": ["node_modules", "dist"]
}
